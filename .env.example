# Sirius Systems — Environment variable template
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` (already in .gitignore).

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://siriussys.io
NEXT_PUBLIC_SITE_NAME="Sirius Systems"

